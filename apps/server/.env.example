PORT=4000

# Allowed web origin(s) for CORS. Comma-separate multiple domains, e.g.
# CORS_ORIGIN=https://sketch-strike.vercel.app,https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# --- Abuse limits (optional; sensible defaults shown) ---
# Max concurrent rooms across the whole server before create_room is refused.
MAX_ROOMS=1000
# Max simultaneous socket connections per client IP.
MAX_CONNECTIONS_PER_IP=30
# Max rooms a single IP can create per minute.
ROOM_CREATE_PER_MIN=12
